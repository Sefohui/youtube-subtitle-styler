{
  "manifest_version": 2,
  "name": "YouTube Subtitle Styler",
  "version": "1.0.0",
  "description": "Force your preferred style settings on YouTube subtitles, overriding YouTube's attempts to reset them.",
  "permissions": [
    "storage",
    "tabs",
    "*://*.youtube.com/*"
  ],
  "icons": {
    "16": "icons/icon.svg",
    "32": "icons/icon.svg",
    "48": "icons/icon.svg",
    "128": "icons/icon.svg"
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "browser_action": {
    "default_popup": "popup.html",
    "default_title": "YouTube Subtitle Styler",
    "default_icon": {
      "16": "icons/icon.svg",
      "32": "icons/icon.svg",
      "48": "icons/icon.svg",
      "128": "icons/icon.svg"
    }
  },
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  }
}
